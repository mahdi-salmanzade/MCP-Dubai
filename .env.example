# MCP-Dubai environment variables.
# Copy to .env (never commit) and fill in the values you need.
# Every variable is OPTIONAL. The server starts and runs all Tier 0 tools
# without any of them. Each variable unlocks a specific tool family.

# ----------------------------------------------------------------------------
# Dubai Pulse OAuth (unlocks all Tier 1 tools: DLD, RTA, DET, DHA, DEWA, etc.)
# Get credentials by requesting dataset access at https://data.dubai
# Token endpoint and dataset URLs are stored under MCP_DUBAI_PULSE_API_BASE.
# ----------------------------------------------------------------------------
MCP_DUBAI_PULSE_CLIENT_ID=
MCP_DUBAI_PULSE_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# Optional base URL overrides.
# Useful when the Dubai Pulse to data.dubai migration completes and the API
# host changes. Defaults are correct for April 2026.
# ----------------------------------------------------------------------------
# MCP_DUBAI_PULSE_API_BASE=https://api.dubaipulse.gov.ae
# MCP_DUBAI_DATA_PORTAL_BASE=https://data.dubai

# ----------------------------------------------------------------------------
# WAQI air quality token (free, sign up at https://aqicn.org/data-platform/token/)
# Unlocks: air_quality_dubai, air_quality_station
# ----------------------------------------------------------------------------
MCP_DUBAI_WAQI_TOKEN=

# ----------------------------------------------------------------------------
# Calendarific API key (free tier 1000 req/day, https://calendarific.com)
# Used by holidays feature for live refresh. Static curated holidays still work
# without this key.
# ----------------------------------------------------------------------------
MCP_DUBAI_CALENDARIFIC_KEY=

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
MCP_DUBAI_LOG_LEVEL=INFO
