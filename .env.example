# ============================================================
# MCP-Dubai Configuration
# ============================================================
# Copy this file to .env and fill in the values you need.
# ALL variables are optional. MCP-Dubai runs 82 tools with zero config.
# See CREDENTIALS.md for the full setup walkthrough.

# ------------------------------------------------------------
# Air Quality (free, ~2 min signup)
# Get your token: https://aqicn.org/data-platform/token/
# Unlocks: air_quality_dubai, air_quality_by_coords, air_quality_dubai_stations
# ------------------------------------------------------------
MCP_DUBAI_WAQI_TOKEN=

# ------------------------------------------------------------
# Dubai Pulse OAuth (free, ~14 day approval)
# Request access at https://www.dubaipulse.gov.ae
# You'll receive an API Key and API Secret in two separate emails.
# Unlocks Tier 1 tools: DLD real estate, RTA transport, DHA, DEWA, DTCM, and more.
# ------------------------------------------------------------
MCP_DUBAI_PULSE_CLIENT_ID=
MCP_DUBAI_PULSE_CLIENT_SECRET=

# ------------------------------------------------------------
# Calendarific (free tier, future use)
# Sign up: https://calendarific.com/signup
# Reserved for automated UAE holiday refresh. Not yet wired up.
# ------------------------------------------------------------
MCP_DUBAI_CALENDARIFIC_KEY=

# ------------------------------------------------------------
# Advanced (usually no need to change)
# ------------------------------------------------------------
# MCP_DUBAI_PULSE_API_BASE=https://api.dubaipulse.gov.ae
# MCP_DUBAI_DATA_PORTAL_BASE=https://data.dubai
# MCP_DUBAI_LOG_LEVEL=INFO
# MCP_DUBAI_HTTP_TIMEOUT=30.0
# MCP_DUBAI_HTTP_MAX_RETRIES=3
